{
  "name": "pixel-pet",
  "version": "0.1.0",
  "description": "A pixel desktop companion (cat + Goldie puppy) that follows your cursor, reacts to typing, and nudges stretch breaks.",
  "main": "src/main/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "gen:assets": "node tools/gen-assets.js",
    "start": "ELECTRON_OZONE_PLATFORM_HINT=x11 electron .",
