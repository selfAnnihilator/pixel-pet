    "electron-builder": "^25.1.8",
    "pngjs": "^7.0.0"
  },
  "dependencies": {
    "uiohook-napi": "^1.5.4"
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "uiohook-napi@1.5.5": true
  }
